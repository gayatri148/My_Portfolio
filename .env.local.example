# ---------------------------------------------------------------
# Contact form -> Supabase (static-site friendly).
# Copy this file to ".env.local" for local dev, and set the SAME
# two variables in Render -> Environment for the deployed site.
#
# These are embedded in the browser at build time, so use the
# PUBLIC anon key (NOT the service_role key). Inserts are protected
# by a Row Level Security "insert" policy on the portfolio table.
# ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
